BOT_TOKEN=123456:put_botfather_token_here

# Optional. If empty, Kcuni replies in simple local demo mode.
# Free-ish option: set AI_PROVIDER=gemini and paste GEMINI_API_KEY from Google AI Studio.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Paid/OpenAI option:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional RSS/news sources. Separate by comma.
NEWS_FEEDS=https://news.google.com/rss?hl=ru&gl=RU&ceid=RU:ru

