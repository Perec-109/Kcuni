BOT_TOKEN=123456:put_botfather_token_here

# Optional outside Render. Render supplies RENDER_EXTERNAL_URL automatically,
# which switches the bot from local long polling to a Telegram webhook.
WEBHOOK_URL=
# Optional override. If empty, a secure value is derived from BOT_TOKEN.
WEBHOOK_SECRET=

# Optional. If empty, Kcuni replies in simple local demo mode.
# Free-ish option: set AI_PROVIDER=gemini and paste GEMINI_API_KEY from Google AI Studio.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Paid/OpenAI option:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional RSS/news sources. Separate by comma.
NEWS_FEEDS=https://news.google.com/rss?hl=ru&gl=RU&ceid=RU:ru

# Local time and proactive messages. New/existing default-schedule users run in
# automatic mode; Kcuni picks different daytime/evening moments each day.
# /schedule HH:MM switches a user to fixed mode; /schedule auto restores auto.
DEFAULT_TIMEZONE=Europe/Minsk
# Fallback and legacy fixed schedule.
PROACTIVE_SCHEDULE=13:00,21:00,23:30
PROACTIVE_CHECK_MINUTES=5
PROACTIVE_SILENCE_MINUTES=360
PROACTIVE_MEDIA_CHANCE=0.04

# Human-like typing delay before text replies.
TYPING_MIN_MS=2000
TYPING_MAX_MS=10000
TYPING_BASE_MS=1800
TYPING_PER_CHAR_MS=28
TYPING_PER_WORD_MS=120
